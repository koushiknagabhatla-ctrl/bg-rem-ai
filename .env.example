# ═══════════════════════════════════════════════════════
# BACKGROUND REMOVAL SAAS — ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════
# Copy this to .env.local (frontend) and set in Render dashboard (backend).
# NEVER commit real values to git.

# ─────────────────────────────────────────────────────
# SUPABASE (get from: supabase.com → Settings → API)
# ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────────────────
# SUPABASE — Backend only (set in Render dashboard)
# ─────────────────────────────────────────────────────
SUPABASE_URL=
# Same service_role key as above, used by FastAPI

# ─────────────────────────────────────────────────────
# UPSTASH REDIS (get from: upstash.com → Redis → REST)
# ─────────────────────────────────────────────────────
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─────────────────────────────────────────────────────
# SECURITY SECRETS — generate with:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────
ADMIN_API_KEY=
WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────
# ADMIN CONFIG
# ─────────────────────────────────────────────────────
ADMIN_EMAIL=koushiknagabhatla@gmail.com

# ─────────────────────────────────────────────────────
# RENDER BACKEND (frontend .env.local + Vercel only)
# ─────────────────────────────────────────────────────
RENDER_API_URL=

# ─────────────────────────────────────────────────────
# BACKEND-ONLY (set in Render dashboard)
# ─────────────────────────────────────────────────────
MODEL_PATH=./model/model_int8.onnx
ALLOWED_ORIGINS=http://localhost:3000
ENV=development
PORT=10000
