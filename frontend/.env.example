# Frontend Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase (public — safe for browser) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend (server-side only — NEVER exposed to browser) ──
RENDER_API_URL=https://bg-removal-api.onrender.com
WEBHOOK_SECRET=your-webhook-secret-must-match-render
ADMIN_API_KEY=your-admin-key-for-direct-access

# ── Vercel Settings ──
# These are set in Vercel dashboard → Settings → Environment Variables
# NEVER commit .env.local to git!
